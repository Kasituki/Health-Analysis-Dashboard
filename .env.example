# ─── Supabase ────────────────────────────────────────────────────────────────
# Supabase プロジェクトのURLとAnon Key（公開可）
NEXT_PUBLIC_SUPABASE_URL=*****
NEXT_PUBLIC_SUPABASE_ANON_KEY=*****

# ─── Gemini API ──────────────────────────────────────────────────────────────
# Google AI Studio で取得したAPIキー（サーバー側のみ使用）
GEMINI_API_KEY=*****

# ─── Basic認証（Vercelデプロイ時に設定） ────────────────────────────────────
BASIC_AUTH_USER=*****
BASIC_AUTH_PASSWORD=*****
